# LLM Provider API key — used by /generate_retention_script.
# Sign up and create a key at your provider's dashboard (e.g. console.groq.com/keys).
# Leave blank to use the static default action plan.
LLM_PROVIDER_API_KEY=

# Hugging Face token — required only if the training dataset is gated.
# HF_TOKEN=

# Disable the slowapi rate limiter (used by load tests / CI).
# LIMITER_ENABLED=true

# Override the FastAPI port. Both the API and the Next.js rewrite
# target honor this so `make dev` works without any config edits.
PORT=8000

# Override the port the Next.js rewrite target points at. Kept
# separate from PORT because Next.js reads PORT for its own listen
# address. Leave unset unless the API and FE live on different hosts.
# BACKEND_PORT=8000
# BACKEND_INTERNAL_URL=http://127.0.0.1:8000
